<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.jjduqu.it-weekly-template</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/jjduqu/.local/bin/it-weekly-template</string>
    </array>

    <!-- Thursday (Weekday 4) at 1:00 PM. If the Mac is asleep at this time,
         launchd runs the job on the next wake. -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>4</integer>
        <key>Hour</key>
        <integer>13</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/jjduqu/Library/Logs/it-weekly-template.launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jjduqu/Library/Logs/it-weekly-template.launchd.log</string>
</dict>
</plist>
